	<field name="seat_booking_booking_date" class="java.lang.String"/>
	<field name="seat_booking_booking_status" class="java.lang.String"/>
	<field name="seat_booking_refund_status" class="java.lang.String"/>
	<group name="seat_booking_id">
		<groupExpression><![CDATA[$F{seat_booking_id}]]></groupExpression>
