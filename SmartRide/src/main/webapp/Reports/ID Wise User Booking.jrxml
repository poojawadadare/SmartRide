	<queryString language="SQL">
		<![CDATA[SELECT
     seat_booking.`id` AS seat_booking_id,
     seat_booking.`booking_id` AS seat_booking_booking_id,
     seat_booking.`user_id` AS seat_booking_user_id,
     seat_booking.`bus_id` AS seat_booking_bus_id,
     seat_booking.`source` AS seat_booking_source,
     seat_booking.`destination` AS seat_booking_destination,
     seat_booking.`seat_number` AS seat_booking_seat_number,
     seat_booking.`passenger_name` AS seat_booking_passenger_name,
     seat_booking.`passenger_age` AS seat_booking_passenger_age,
     seat_booking.`journey_date` AS seat_booking_journey_date,
     seat_booking.`booking_date` AS seat_booking_booking_date,
     seat_booking.`booking_status` AS seat_booking_booking_status,
     seat_booking.`refund_status` AS seat_booking_refund_status
FROM
     `seat_booking` seat_booking]]>
	</queryString>
